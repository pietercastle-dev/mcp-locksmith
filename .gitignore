# This is a plugin/marketplace repo — a consumed .mcp.json must never live at the
# root here (it would leak whoever-ran-it's server topology). Anchored so the tracked
# plugins/mcp-globals/.mcp.json template is unaffected.
/.mcp.json

# Never commit decrypted secrets or local backend state.
*.sops.decrypted
*.decrypted
.env
.env.*
secrets.yaml
*.key
keys.txt

# Python
__pycache__/
*.pyc
