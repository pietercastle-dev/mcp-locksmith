# This is a plugin/marketplace repo: a consumed .mcp.json must never live at the
# root here (it would leak whoever-ran-it's server topology). Anchored so tracked
# templates (plugins/mcp-secure/templates/) are unaffected.
/.mcp.json

# Local session state and reference material; never part of the published tree.
/.claude/
/seceng-claude-main/

# Never commit decrypted secrets or local backend state.
*.sops.decrypted
*.decrypted
.env
.env.*
secrets.yaml
*.key
keys.txt

# Python
__pycache__/
*.pyc
