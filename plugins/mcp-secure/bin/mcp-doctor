#!/usr/bin/env python3
"""mcp-doctor — health-check the MCP secret chain.

Verifies, for the current setup:
  - mcp-secret / mcp-launch are reachable
  - the configured secret backend CLI is installed and authenticated
  - every secret reference in your MCP config(s) actually resolves

References are resolved by calling mcp-secret; this NEVER prints secret values —
only the reference and pass/fail. Exits non-zero if anything fails.

Usage: mcp-doctor [--launch] [config.json ...]
  Defaults to ./.mcp.json and ~/.claude.json when no paths are given.
  --launch additionally spawns each stdio server briefly (via `mcp-pin tools`)
  and reports whether it starts and speaks MCP — with the server's own stderr
  when it doesn't. The troubleshooting mode /mcp-secure:fix uses.
"""
import json
import os
import re
import shutil
import subprocess
import sys

G = "\033[1;32m"; R = "\033[1;31m"; Y = "\033[1;33m"; B = "\033[1;34m"; X = "\033[0m"
def ok(m):   print(f"  {G}✔{X} {m}")
def bad(m):  print(f"  {R}✘{X} {m}")
def warn(m): print(f"  {Y}!{X} {m}")
def tip(m):  print(f"  {B}i{X} {m}")
def info(m): print(f"  {B}i{X} {m}")
def head(m): print(f"\n{B}=={X} {m}")

fails = 0

here = os.path.dirname(os.path.realpath(__file__))
mcp_secret = os.environ.get("MCP_SECRET_BIN") or os.path.join(here, "mcp-secret")
if not (mcp_secret and os.access(mcp_secret, os.X_OK)):
    mcp_secret = shutil.which("mcp-secret")
mcp_launch = os.path.join(here, "mcp-launch")
if not os.access(mcp_launch, os.X_OK):
    mcp_launch = shutil.which("mcp-launch")

head("tooling")
if mcp_secret:
    ok(f"mcp-secret: {mcp_secret}")
else:
    bad("mcp-secret not found — run install.sh"); fails += 1
if mcp_launch:
    ok(f"mcp-launch: {mcp_launch}")
else:
    warn("mcp-launch not on PATH — project .mcp.json servers using it won't spawn")
if shutil.which("sfw"):
    ok("sfw present (Socket Firewall — install-time package protection)")
else:
    tip("optional: 'npm i -g sfw' to block malicious packages when installing MCP servers")

# --- organization (optional org.json) ---
org_path = os.path.expanduser(os.environ.get("MCP_ORG_CONFIG", "~/.config/mcp-secret/org.json"))
if os.path.exists(org_path):
    head("organization")
    try:
        org = json.load(open(org_path))
    except Exception as e:
        warn(f"org config at {org_path} is invalid JSON: {e}")
    else:
        if org.get("org"):
            ok(f"org: {org['org']}")
        if org.get("docsUrl"):
            tip(f"internal MCP docs: {org['docsUrl']}")
        if org.get("recommended"):
            tip(f"recommended bundles: {', '.join(org['recommended'])}")
        gw = (org.get("gateway") or {}).get("url")
        if gw:
            tip(f"org gateway (info only — routing not enforced): {gw}")

# --- secret backend ---
cfg_path = os.path.expanduser(os.environ.get("MCP_SECRET_CONFIG", "~/.config/mcp-secret/config"))
cfg = {}
if os.path.exists(cfg_path):
    for line in open(cfg_path):
        line = line.strip()
        if line and not line.startswith("#") and "=" in line:
            k, v = line.split("=", 1)
            cfg[k.strip()] = v.strip()
backend = cfg.get("MCP_SECRET_BACKEND")

HAVE_BREW = bool(shutil.which("brew"))
BACKENDS_DOC = "secure setup: plugins/mcp-secure/BACKENDS.md"

def install_hint(*pkgs):
    if HAVE_BREW:
        return f"install: brew install {' '.join(pkgs)}"
    return f"install {', '.join(pkgs)} from the official source — {BACKENDS_DOC}"

head("secret backend")
if not backend:
    warn(f"no default backend in {cfg_path} (only fully-qualified refs will resolve)")
    tip(f"pick one (1Password / Bitwarden / SOPS) — {BACKENDS_DOC}")
else:
    ok(f"default backend: {backend}")
    if backend == "op":
        if not shutil.which("op"):
            bad("op CLI not installed"); fails += 1
            tip(install_hint("1password-cli")); tip(BACKENDS_DOC)
        elif subprocess.run(["op", "whoami"], capture_output=True).returncode == 0:
            ok("1Password signed in")
        else:
            bad("1Password not signed in"); fails += 1
            tip("sign in: `op signin` (enable CLI integration in the 1Password app first)")
    elif backend == "sops":
        if not shutil.which("sops"):
            bad("sops not installed"); fails += 1
            tip(install_hint("sops", "age")); tip(BACKENDS_DOC)
        keyfile = os.environ.get("SOPS_AGE_KEY_FILE") or os.path.expanduser("~/.config/sops/age/keys.txt")
        if os.environ.get("SOPS_AGE_KEY") or os.path.exists(keyfile):
            ok("age key present")
        else:
            warn(f"no age key at {keyfile} or $SOPS_AGE_KEY — decryption will fail")
            tip("generate one: `age-keygen -o ~/.config/sops/age/keys.txt && chmod 600 "
                "~/.config/sops/age/keys.txt` (or re-run install.sh) — never commit it")
    elif backend == "bw":
        if not shutil.which("bw"):
            bad("bw CLI not installed"); fails += 1
            tip(install_hint("bitwarden-cli", "jq")); tip(BACKENDS_DOC)
        else:
            r = subprocess.run(["bw", "status"], capture_output=True, text=True)
            try:
                st = json.loads(r.stdout).get("status", "")
            except Exception:
                st = ""
            if st == "unlocked":
                ok("bitwarden unlocked")
            else:
                warn(f"bitwarden status: {st or 'unknown'}")
                tip('unlock: `export BW_SESSION="$(bw unlock --raw)"` in this shell')
        if not shutil.which("jq"):
            warn("jq not installed (needed for bw refs)"); tip(install_hint("jq"))


# Literal-secret detection for EXISTING config (mirrors mcp-guard.py — keep in sync).
# The guard stops new secrets going in; this catches ones already sitting in config.
_SECRET_KEY = re.compile(
    r"(TOKEN|SECRET|PASSWORD|PASSWD|APIKEY|API_KEY|ACCESS_KEY|PRIVATE_KEY|"
    r"CREDENTIAL|CLIENT_SECRET|AUTH|BEARER|\bKEY\b|\bPAT\b)", re.I)
_SECRET_VAL = re.compile(
    r"(ghp_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|"
    r"xox[baprs]-[A-Za-z0-9-]{10,}|sk-[A-Za-z0-9]{20,}|"
    r"AKIA[0-9A-Z]{16}|eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}|"
    r"AIza[0-9A-Za-z_\-]{30,}|-----BEGIN[ A-Z]*PRIVATE KEY-----|"
    r"[a-z][a-z0-9+.\-]*://[^/?#@\s:]+:[^/?#@\s]+@)")
_SAFE_VAL = re.compile(
    r"^\s*(?:(?:Bearer|Basic|Token)\s+)?(\$\{[^}]+\}|\$[A-Za-z_]\w*|op://|sops://|bw://)",
    re.I)


def _looks_secret(key, val):
    if not isinstance(val, str) or not val.strip() or _SAFE_VAL.search(val):
        return False
    if _SECRET_VAL.search(val):
        return True
    return bool(key and _SECRET_KEY.search(key) and len(val.strip()) >= 12)


def inline_secrets(spec):
    """Literal secrets sitting in a server's env/args (not a reference).

    env uses the key+value heuristic (env names like GITHUB_TOKEN are meaningful).
    args are matched on value SHAPE only — a CLI flag name like `--secret` is not a
    reliable key, and `mcp-launch --secret NAME=op://…` must not be mistaken for a
    leak. A credential-shaped value (`ghp_…`, `sk-…`, `user:pass@`) is caught
    wherever it sits; a reference (`op://…`) is not.
    """
    hits = []
    for k, v in (spec.get("env") or {}).items():
        if _looks_secret(k, v):
            hits.append(f"env.{k}")
    # http/sse servers: a stored auth header is a literal secret too.
    for k, v in (spec.get("headers") or {}).items():
        if _looks_secret(k, v):
            hits.append(f"headers.{k}")
    for i, a in enumerate(spec.get("args") or []):
        if isinstance(a, str) and _SECRET_VAL.search(a):
            hits.append(f"args[{i}]")
    return hits


def refs_from_server(spec):
    refs = set()
    args = spec.get("args") or []
    i = 0
    while i < len(args):
        a = args[i]
        if a in ("--secret", "--arg") and i + 1 < len(args):
            pair = args[i + 1]; i += 2
            if "=" in pair:
                refs.add(pair.split("=", 1)[1])
            continue
        if a.startswith(("--secret=", "--arg=")):
            pair = a.split("=", 1)[1]
            if "=" in pair:
                refs.add(pair.split("=", 1)[1])
        i += 1
    def scan(v):
        if isinstance(v, str) and v.startswith(("op://", "sops://", "bw://")):
            refs.add(v)
    for v in args:
        scan(v)
    for v in (spec.get("env") or {}).values():
        scan(v)
    return refs


argv = sys.argv[1:]
LAUNCH = "--launch" in argv
argv = [a for a in argv if a != "--launch"]
paths = argv or [p for p in ["./.mcp.json", os.path.expanduser("~/.claude.json")] if os.path.exists(p)]

collected = []
inline_found = []
all_servers = []
for p in paths:
    try:
        data = json.load(open(p))
    except Exception as e:
        warn(f"skip {p}: {e}"); continue
    for name, spec in (data.get("mcpServers") or {}).items():
        if isinstance(spec, dict):
            all_servers.append((name, spec))
            for ref in refs_from_server(spec):
                collected.append((name, ref))
            for where in inline_secrets(spec):
                inline_found.append((p, name, where))

# --- literal secrets already in config (the guard only stops NEW ones) ---
head("inline secrets")
if not paths:
    info("no MCP config files found")
elif not inline_found:
    ok("no literal secrets in config")
else:
    for p, name, where in inline_found:
        bad(f"{name}: literal secret at {where} in {p}"); fails += 1
    tip("move it to a reference: keep the value in your vault and launch via "
        "mcp-launch (op://… / sops://… / bw://…). /mcp-secure:audit can migrate it.")

head("reference resolution")
if not paths:
    warn("no MCP config files found (./.mcp.json, ~/.claude.json)")
elif not collected:
    ok("no secret references found in configs")
elif not mcp_secret:
    bad("can't resolve references — mcp-secret missing"); fails += 1
else:
    for name, ref in collected:
        r = subprocess.run([mcp_secret, ref], capture_output=True, text=True)
        if r.returncode == 0 and r.stdout.strip():
            ok(f"{name}: {ref}")
        else:
            bad(f"{name}: {ref} — {r.stderr.strip() or 'empty/failed'}"); fails += 1

# --- optional: actually launch each stdio server and speak MCP to it ---
if LAUNCH:
    head("server launch")
    ANSI = re.compile(r"\033\[[0-9;]*m")
    mcp_pin = os.path.join(here, "mcp-pin")
    launched = 0
    for name, spec in all_servers:
        if spec.get("type") in ("http", "sse") or spec.get("url"):
            tip(f"{name}: remote — launch check n/a (verify by connecting in a session)")
            continue
        cmd = os.path.expandvars(spec.get("command", ""))
        args = [os.path.expandvars(a) if isinstance(a, str) else a
                for a in (spec.get("args") or [])]
        if not cmd:
            bad(f"{name}: no command in config"); fails += 1
            continue
        launched += 1
        env = dict(os.environ)
        for k, v in (spec.get("env") or {}).items():
            env[k] = os.path.expandvars(v) if isinstance(v, str) else v
        try:
            r = subprocess.run([sys.executable, mcp_pin, "tools", "--", cmd] + args,
                               capture_output=True, text=True, env=env, timeout=60)
        except subprocess.TimeoutExpired:
            bad(f"{name}: did not respond within 60s"); fails += 1
            continue
        if r.returncode == 0:
            try:
                ok(f"{name}: launches and speaks MCP ({len(json.loads(r.stdout))} tools)")
            except Exception:
                ok(f"{name}: launches and speaks MCP")
        else:
            msg = ANSI.sub("", (r.stdout + r.stderr).strip()).splitlines()
            bad(f"{name}: {msg[-1].strip() if msg else 'failed to launch'}"); fails += 1
            low = " ".join(msg).lower()
            if "no such file" in low or "not found" in low:
                tip("the command isn't installed/on PATH — is its runtime (node/npx, uvx) present?")
            if "unresolved ${" in low:
                tip("config uses ${…} the shell can't expand here — plugin-scope server?")
            if "failed to resolve" in low:
                tip("a secret reference didn't resolve — run the checks above / see BACKENDS.md")
    if launched == 0:
        info("no stdio servers to launch")

head("summary")
if fails == 0:
    print(f"  {G}all good{X}")
    if not LAUNCH:
        tip("deeper checks: `mcp-doctor --launch` spawns each tool briefly to prove it starts;")
        tip("`mcp-pin verify` checks tools haven't changed since you approved them")
    sys.exit(0)
print(f"  {R}{fails} problem(s){X}")
sys.exit(1)
