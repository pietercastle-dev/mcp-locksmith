#!/usr/bin/env bash
# mcp-secret — resolve a single secret reference to plaintext on stdout.
#
# Part of the claude-bootstrap MCP harness. MCP server wrappers call this at
# launch so the credential never lands in ~/.claude.json, never lands in a
# committed .mcp.json, and never reaches Claude's context.
#
# Usage:
#   mcp-secret <ref>
#
# Reference forms:
#   Short ref (resolved via the machine default backend):
#     mcp-secret cloudflare/token        # item/field
#     mcp-secret cloudflare              # item (field defaults to "password")
#   Fully-qualified ref (backend explicit, ignores the default):
#     mcp-secret op://Work/cloudflare/token
#     mcp-secret op://Work/cloudflare/section/token
#     mcp-secret sops://~/secrets/mcp.sops.yaml#/cloudflare/token
#     mcp-secret bw://cloudflare/token
#
# Backends: op (1Password CLI), sops (SOPS+age), bw (Bitwarden CLI).
# Reference syntax intentionally mirrors helmfile/vals + 1Password's op://.
#
# Machine config (sourced if present): ~/.config/mcp-secret/config
#   MCP_SECRET_BACKEND=op|sops|bw     # default backend for short refs
#   MCP_OP_VAULT=<vault>              # default vault for op short refs
#   MCP_SOPS_FILE=<path>             # default file for sops short refs
#
# Output: the raw secret value, no added newline. Errors go to stderr.
set -euo pipefail

err() { printf 'mcp-secret: %s\n' "$*" >&2; exit 1; }
emit() { printf '%s' "$1"; }   # no trailing newline; $(...) callers strip it anyway

CONFIG="${MCP_SECRET_CONFIG:-$HOME/.config/mcp-secret/config}"
# Parse the config as KEY=VALUE — do NOT `source` it. Sourcing would execute the
# file as shell, so a writable config = arbitrary code execution at every resolve.
# Only a fixed allow-list of keys is honored; everything else is ignored.
if [ -f "$CONFIG" ]; then
  while IFS= read -r _line || [ -n "$_line" ]; do
    case "$_line" in ''|'#'*) continue ;; esac
    _k="${_line%%=*}"; _v="${_line#*=}"
    _k="${_k#"${_k%%[![:space:]]*}"}"; _k="${_k%"${_k##*[![:space:]]}"}"
    _v="${_v#"${_v%%[![:space:]]*}"}"; _v="${_v%"${_v##*[![:space:]]}"}"
    case "$_k" in
      MCP_SECRET_BACKEND) MCP_SECRET_BACKEND="$_v" ;;
      MCP_OP_VAULT)       MCP_OP_VAULT="$_v" ;;
      MCP_SOPS_FILE)      MCP_SOPS_FILE="$_v" ;;
    esac
  done < "$CONFIG"
fi

[ $# -eq 1 ] || err "usage: mcp-secret <ref>"
ref="$1"

resolve_op() {
  # $1 = full op:// reference
  command -v op >/dev/null 2>&1 || err "1Password CLI 'op' not found"
  local out
  out="$(op read --no-newline "$1" 2>/dev/null)" \
    || err "op read failed for '$1' (signed in? try 'op signin')"
  emit "$out"
}

resolve_sops() {
  # $1 = file, $2 = fragment path (e.g. /cloudflare/token or CF_TOKEN)
  command -v sops >/dev/null 2>&1 || err "sops not found"
  local file="$1" frag="$2" extract="" p
  file="${file/#\~/$HOME}"
  # Reject path traversal — a ref comes from (possibly untrusted) config, so don't
  # let `sops://~/../../some/other.file` read outside the intended location.
  case "$file" in *..*) err "sops path may not contain '..': $file" ;; esac
  [ -f "$file" ] || err "sops file not found: $file"
  local IFS='/'
  # shellcheck disable=SC2206
  local parts=( $frag )
  # ${parts+…} guards the empty-fragment case: bash 3.2 (macOS default) treats
  # expanding an empty array as unbound under `set -u`.
  for p in ${parts+"${parts[@]}"}; do
    [ -n "$p" ] && extract+="[\"$p\"]"
  done
  [ -n "$extract" ] || err "sops ref needs a key fragment (…#/key)"
  # Point sops at the age key we manage, unless the user set one. sops's default
  # key location is platform-specific (~/Library/Application Support on macOS, not
  # ~/.config), so it won't find the key install.sh writes to ~/.config/sops/age.
  if [ -z "${SOPS_AGE_KEY:-}" ] && [ -z "${SOPS_AGE_KEY_FILE:-}" ] \
     && [ -f "$HOME/.config/sops/age/keys.txt" ]; then
    export SOPS_AGE_KEY_FILE="$HOME/.config/sops/age/keys.txt"
  fi
  local out
  out="$(sops -d --extract "$extract" "$file" 2>/dev/null)" \
    || err "sops decrypt/extract failed: $file $extract"
  emit "$out"
}

resolve_bw() {
  # $1 = item, $2 = field (optional; default "password")
  command -v bw >/dev/null 2>&1 || err "Bitwarden CLI 'bw' not found"
  command -v jq >/dev/null 2>&1 || err "jq required for bw refs"
  local item="$1" field="${2:-password}" json out
  json="$(bw get item "$item" --raw 2>/dev/null)" \
    || err "bw get item '$item' failed (unlocked? 'bw unlock' + export BW_SESSION)"
  out="$(printf '%s' "$json" | jq -r --arg f "$field" '
        (.login[$f]? // empty)
        // (.fields[]? | select(.name == $f) | .value)
        // empty')"
  [ -n "$out" ] || err "field '$field' not found on bw item '$item'"
  emit "$out"
}

case "$ref" in
  op://*)
    resolve_op "$ref"
    ;;
  sops://*)
    rest="${ref#sops://}"
    file="${rest%%#*}"
    if [ "$rest" = "${rest#*#}" ]; then frag=""; else frag="${rest#*#}"; fi
    resolve_sops "$file" "$frag"
    ;;
  bw://*)
    rest="${ref#bw://}"
    bw_item="${rest%%/*}"
    if [ "$rest" = "${rest#*/}" ]; then bw_field=""; else bw_field="${rest#*/}"; fi
    resolve_bw "$bw_item" "$bw_field"
    ;;
  *://*)
    err "unknown backend scheme in ref: $ref"
    ;;
  *)
    # Short ref → expand via the machine default backend.
    [ -n "$ref" ] || err "empty reference"
    backend="${MCP_SECRET_BACKEND:-}"
    [ -n "$backend" ] || err "short ref '$ref' but MCP_SECRET_BACKEND not set (see $CONFIG)"
    item="${ref%%/*}"
    if [ "$ref" = "${ref#*/}" ]; then field=""; else field="${ref#*/}"; fi
    case "$backend" in
      op)
        [ -n "${MCP_OP_VAULT:-}" ] || err "MCP_OP_VAULT not set for op backend"
        resolve_op "op://$MCP_OP_VAULT/$item/${field:-password}"
        ;;
      sops)
        [ -n "${MCP_SOPS_FILE:-}" ] || err "MCP_SOPS_FILE not set for sops backend"
        if [ -n "$field" ]; then resolve_sops "$MCP_SOPS_FILE" "/$item/$field"
        else resolve_sops "$MCP_SOPS_FILE" "/$item"; fi
        ;;
      bw)
        resolve_bw "$item" "$field"
        ;;
      *)
        err "unknown MCP_SECRET_BACKEND: $backend"
        ;;
    esac
    ;;
esac
