#!/usr/bin/env python3
"""mcp-pin: pin MCP servers' tool definitions and detect drift (rug-pulls).

Speaks just enough of the MCP protocol (a minimal stdio JSON-RPC client) to ask
each configured server for its tool list, hashes the security-relevant fields
(name/title/description/input+outputSchema/annotations), and compares against a
stored baseline. A change to an already-approved tool is a rug-pull signal; a
new/unknown tool is something to review for tool-poisoning before pinning.

Discovers servers wherever they live, NO repo required:
  - ./.mcp.json (when you're in a repo)
  - ~/.claude.json: user-scope mcpServers + the current dir's project entry

Pins live per-user at ~/.config/mcp-secret/pins.json, keyed by server identity
(name + command + args; name + url for remote servers), so a version bump
reads as "new, re-pin".

Usage:
  mcp-pin                 verify all discovered servers (default)
  mcp-pin verify [name…]
  mcp-pin pin [name…]     record/update the baseline (after vetting)
  mcp-pin list            show what's pinned
  mcp-pin unpin <name…>   drop the baseline for a server you removed
  mcp-pin prune [--yes]   drop pins with no matching server here (dry-run w/o --yes)
  mcp-pin tools -- <command> [args…]
                          plumbing: launch a command and print its MCP tool list
                          as JSON, lets /mcp-secure:update diff a candidate
                          version's tools against the current one before adopting

Covers stdio and streamable-HTTP servers (honoring `headers`/`headersHelper`).
Known gap, labeled honestly: a remote server that authenticates via Claude
Code's OAuth store can't be listed here (that token isn't ours to read). Those
fail with a message saying so. Legacy `type: "sse"` servers are skipped with a
note. Exit non-zero if any server drifts from its pin or fails to verify.
"""
import hashlib
import json
import os
import queue
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.request

G = "\033[1;32m"; R = "\033[1;31m"; Y = "\033[1;33m"; B = "\033[1;34m"; X = "\033[0m"
def ok(m):   print(f"  {G}✔{X} {m}")
def bad(m):  print(f"  {R}✘{X} {m}")
def warn(m): print(f"  {Y}!{X} {m}")
def info(m): print(f"  {B}i{X} {m}")
def head(m): print(f"\n{B}=={X} {m}")

PINS = os.path.expanduser(os.environ.get("MCP_PINS_FILE", "~/.config/mcp-secret/pins.json"))
TIMEOUT = float(os.environ.get("MCP_PIN_TIMEOUT", "20"))
# Some edge WAFs (Cloudflare's, notably mcp.cloudflare.com) 403 the default
# `Python-urllib/x.y` User-Agent before the request reaches the MCP server, so a
# config that connects fine in a real session fails to verify here. Send a named
# UA; a `headers`/`headersHelper` that sets its own User-Agent still wins.
USER_AGENT = "mcp-pin/0.1 (mcp-secure)"


def load_pins():
    try:
        return json.load(open(PINS))
    except Exception:
        return {}


def save_pins(p):
    os.makedirs(os.path.dirname(PINS), exist_ok=True)
    with open(PINS, "w") as f:
        json.dump(p, f, indent=2, sort_keys=True)
        f.write("\n")


def expand(s):
    return os.path.expandvars(s) if isinstance(s, str) else s


def identity(name, command, args):
    raw = name + "\0" + command + "\0" + json.dumps(args, sort_keys=True)
    return hashlib.sha256(raw.encode()).hexdigest()[:16]


def tool_hash(tool):
    keep = {k: tool[k] for k in ("name", "title", "description", "inputSchema",
                                 "outputSchema", "annotations") if k in tool}
    return hashlib.sha256(json.dumps(keep, sort_keys=True, separators=(",", ":")).encode()).hexdigest()


def discover():
    servers = {}
    home = os.path.expanduser("~")
    cwd = os.getcwd()
    p = os.path.join(cwd, ".mcp.json")
    if os.path.exists(p):
        try:
            for n, s in (json.load(open(p)).get("mcpServers") or {}).items():
                servers.setdefault(n, s)
        except Exception as e:
            warn(f"skip {p}: {e}")
    try:
        data = json.load(open(os.path.join(home, ".claude.json")))
        for n, s in (data.get("mcpServers") or {}).items():
            servers.setdefault(n, s)
        for n, s in (((data.get("projects") or {}).get(cwd) or {}).get("mcpServers") or {}).items():
            servers.setdefault(n, s)
    except Exception:
        pass
    return servers


def list_tools_stdio(spec):
    """Launch a stdio server, handshake, return its tool dicts. Raises on failure."""
    command = expand(spec.get("command", ""))
    args = [expand(a) for a in (spec.get("args") or [])]
    if not command:
        raise RuntimeError("no command")
    if "${" in command or any("${" in a for a in args):
        raise RuntimeError("unresolved ${…} in command/args (plugin-scope server?)")
    env = dict(os.environ)
    for k, v in (spec.get("env") or {}).items():
        env[k] = expand(v)

    # Capture stderr (to a temp file, no pipe-deadlock risk) so a failure can
    # say WHY: npx fetch errors, missing runtimes, mcp-launch resolve failures.
    errf = tempfile.TemporaryFile(mode="w+", errors="replace")
    proc = subprocess.Popen([command] + args, stdin=subprocess.PIPE, stdout=subprocess.PIPE,
                            stderr=errf, text=True, env=env)
    deadline = time.time() + TIMEOUT
    q = queue.Queue()

    def err_tail():
        try:
            errf.seek(0)
            lines = [ln.strip() for ln in errf.read().splitlines() if ln.strip()]
            return (", server stderr: " + " | ".join(lines[-3:])) if lines else ""
        except Exception:
            return ""

    def reader():
        try:
            for line in proc.stdout:
                q.put(line)
        finally:
            q.put(None)
    threading.Thread(target=reader, daemon=True).start()

    def send(msg):
        proc.stdin.write(json.dumps(msg) + "\n")
        proc.stdin.flush()

    def recv(want_id):
        while True:
            remaining = deadline - time.time()
            if remaining <= 0:
                raise RuntimeError("timeout" + err_tail())
            try:
                line = q.get(timeout=remaining)
            except queue.Empty:
                raise RuntimeError("timeout" + err_tail())
            if line is None:
                raise RuntimeError("server closed stdout / exited" + err_tail())
            line = line.strip()
            if not line:
                continue
            try:
                msg = json.loads(line)
            except Exception:
                continue  # ignore non-JSON noise on stdout
            if msg.get("id") == want_id:
                return msg

    try:
        send({"jsonrpc": "2.0", "id": 1, "method": "initialize", "params": {
            "protocolVersion": "2025-06-18", "capabilities": {},
            "clientInfo": {"name": "mcp-pin", "version": "0.1"}}})
        resp = recv(1)
        if "error" in resp:
            raise RuntimeError(f"initialize error: {resp['error']}")
        send({"jsonrpc": "2.0", "method": "notifications/initialized"})
        tools, cursor, rid = [], None, 2
        while True:
            params = {} if cursor is None else {"cursor": cursor}
            send({"jsonrpc": "2.0", "id": rid, "method": "tools/list", "params": params})
            resp = recv(rid); rid += 1
            if "error" in resp:
                raise RuntimeError(f"tools/list error: {resp['error']}")
            res = resp.get("result") or {}
            tools.extend(res.get("tools") or [])
            cursor = res.get("nextCursor")
            if not cursor:
                break
        return tools
    finally:
        try:
            proc.terminate(); proc.wait(timeout=3)
        except Exception:
            try:
                proc.kill()
            except Exception:
                pass
        try:
            errf.close()
        except Exception:
            pass


def http_headers(spec):
    """Static `headers` merged with `headersHelper` output (helper wins). The
    same contract Claude Code uses, so a config that connects in a session
    authenticates identically here. The helper is a shell command that prints
    a JSON object of headers."""
    hdrs = {k: expand(v) for k, v in (spec.get("headers") or {}).items()}
    helper = spec.get("headersHelper")
    if helper:
        r = subprocess.run(helper, shell=True, capture_output=True, text=True, timeout=TIMEOUT)
        if r.returncode != 0:
            tail = (r.stderr or r.stdout).strip().splitlines()
            raise RuntimeError("headersHelper failed" + (f": {tail[-1]}" if tail else ""))
        try:
            got = json.loads(r.stdout)
            if not isinstance(got, dict):
                raise ValueError
        except Exception:
            raise RuntimeError("headersHelper must print a JSON object of headers")
        hdrs.update({k: str(v) for k, v in got.items()})
    return hdrs


def list_tools_http(spec):
    """Streamable-HTTP transport: POST JSON-RPC to the url, accepting both
    application/json and text/event-stream response bodies and threading
    Mcp-Session-Id. Raises on failure."""
    url = expand(spec.get("url", ""))
    if not url:
        raise RuntimeError("no url")
    if "${" in url:
        raise RuntimeError("unresolved ${…} in url (plugin-scope server?)")
    auth = http_headers(spec)
    deadline = time.time() + TIMEOUT
    session_id = None

    def rpc(payload, want_id):
        nonlocal session_id
        remaining = deadline - time.time()
        if remaining <= 0:
            raise RuntimeError("timeout")
        hdrs = dict(auth)
        hdrs["Content-Type"] = "application/json"
        hdrs["Accept"] = "application/json, text/event-stream"
        hdrs.setdefault("MCP-Protocol-Version", "2025-06-18")
        hdrs.setdefault("User-Agent", USER_AGENT)
        if session_id:
            hdrs["Mcp-Session-Id"] = session_id
        req = urllib.request.Request(url, data=json.dumps(payload).encode(),
                                     headers=hdrs, method="POST")
        try:
            resp = urllib.request.urlopen(req, timeout=remaining)
        except urllib.error.HTTPError as e:
            if e.code in (401, 403) and not auth:
                raise RuntimeError(
                    f"HTTP {e.code}: the server wants auth and this config has no "
                    "headers/headersHelper. If it authenticates via Claude Code's "
                    "OAuth store, that token isn't reachable from here (a "
                    "documented gap, see README).")
            raise RuntimeError(f"HTTP {e.code} {e.reason}")
        except Exception as e:
            raise RuntimeError(f"cannot reach {url}: {getattr(e, 'reason', e)}")
        with resp:
            sid = resp.headers.get("Mcp-Session-Id")
            if sid:
                session_id = sid
            if want_id is None:
                return None
            ctype = (resp.headers.get("Content-Type") or "").split(";")[0].strip().lower()
            if ctype == "text/event-stream":
                # The response arrives as SSE `data:` lines; read incrementally
                # and stop at the matching id (servers may keep the stream open).
                data_lines = []
                for raw in resp:
                    if time.time() > deadline:
                        raise RuntimeError("timeout reading event stream")
                    line = raw.decode("utf-8", "replace").rstrip("\r\n")
                    if line.startswith("data:"):
                        data_lines.append(line[5:].lstrip())
                        continue
                    if line:
                        continue  # other SSE fields (event:, id:), irrelevant here
                    if data_lines:
                        try:
                            msg = json.loads("\n".join(data_lines))
                        except Exception:
                            msg = None
                        data_lines = []
                        if isinstance(msg, dict) and msg.get("id") == want_id:
                            return msg
                try:  # stream ended without a trailing blank line
                    msg = json.loads("\n".join(data_lines))
                except Exception:
                    msg = None
                if isinstance(msg, dict) and msg.get("id") == want_id:
                    return msg
                raise RuntimeError("event stream ended without a response")
            body = resp.read().decode("utf-8", "replace")
            if not body.strip():
                return None
            try:
                msg = json.loads(body)
            except Exception:
                raise RuntimeError(f"non-JSON response ({ctype or 'no content-type'})")
            if isinstance(msg, dict) and msg.get("id") == want_id:
                return msg
            raise RuntimeError("response id mismatch")

    try:
        resp = rpc({"jsonrpc": "2.0", "id": 1, "method": "initialize", "params": {
            "protocolVersion": "2025-06-18", "capabilities": {},
            "clientInfo": {"name": "mcp-pin", "version": "0.1"}}}, 1)
        if resp is None:
            raise RuntimeError("no response to initialize")
        if "error" in resp:
            raise RuntimeError(f"initialize error: {resp['error']}")
        try:
            rpc({"jsonrpc": "2.0", "method": "notifications/initialized"}, None)
        except Exception:
            pass  # some servers reject the notification; tools/list may still work
        tools, cursor, rid = [], None, 2
        while True:
            params = {} if cursor is None else {"cursor": cursor}
            resp = rpc({"jsonrpc": "2.0", "id": rid, "method": "tools/list", "params": params}, rid)
            rid += 1
            if resp is None:
                raise RuntimeError("no response to tools/list")
            if "error" in resp:
                raise RuntimeError(f"tools/list error: {resp['error']}")
            res = resp.get("result") or {}
            tools.extend(res.get("tools") or [])
            cursor = res.get("nextCursor")
            if not cursor:
                break
        return tools
    finally:
        if session_id:  # politely end the session (optional per spec)
            try:
                req = urllib.request.Request(
                    url, headers=dict({"User-Agent": USER_AGENT}, **auth,
                                      **{"Mcp-Session-Id": session_id}), method="DELETE")
                urllib.request.urlopen(req, timeout=3).close()
            except Exception:
                pass


def list_tools(spec):
    return list_tools_http(spec) if is_remote(spec) else list_tools_stdio(spec)


def current_hashes(spec):
    return {t["name"]: tool_hash(t) for t in list_tools(spec) if isinstance(t, dict) and "name" in t}


def is_remote(spec):
    return spec.get("type") in ("http", "sse") or bool(spec.get("url"))


def is_legacy_sse(spec):
    return spec.get("type") == "sse"


def spec_target(spec):
    """Identity inputs for either transport: (command, args) for stdio,
    (url, []) for remote. The url sits in the command slot so the hash
    scheme (and every keep-in-sync copy of identity()) stays unchanged."""
    if is_remote(spec):
        return expand(spec.get("url", "")), []
    return expand(spec.get("command", "")), [expand(a) for a in (spec.get("args") or [])]


def select(names):
    servers = discover()
    sel = {n: s for n, s in servers.items() if not names or n in names}
    return sel


def cmd_pin(names):
    replace = any(a in ("--replace", "-r") for a in names)
    names = [n for n in names if not n.startswith("-")]
    pins = load_pins()
    sel = select(names)
    if not sel:
        warn("no matching servers found"); return 0
    head("pinning")
    fails = 0
    for n, s in sel.items():
        if is_legacy_sse(s):
            warn(f"{n}: legacy SSE transport. Can't pin (migrate to streamable http)"); continue
        try:
            hashes = current_hashes(s)
        except Exception as e:
            bad(f"{n}: {e}"); fails += 1; continue
        cmd, args = spec_target(s)
        new_id = identity(n, cmd, args)
        entry = {"name": n, "tools": hashes,
                 "pinnedAt": time.strftime("%Y-%m-%dT%H:%M:%S")}
        if is_remote(s):
            entry["url"] = cmd
        else:
            entry["command"] = cmd; entry["args"] = args
        # Superseded pins: same name, DIFFERENT identity. The server as configured
        # here now hashes to new_id, so any other same-name pin is a stale baseline
        # from before its command/args/url changed (version bump, migration, a
        # reverted migration). Left in place these accumulate as orphans, and
        # worse, a later `verify` can match the WRONG baseline and cry drift.
        # --replace drops them (the re-pin FLOWS pass it, since supersession is the
        # whole point there); a bare pin only FLAGS them, because a same-name pin
        # *could* belong to that server in another repo not discoverable from here.
        superseded = [k for k in pins
                      if pins[k].get("name") == n and k != new_id]
        pins[new_id] = entry
        ok(f"{n}: pinned {len(hashes)} tool(s)")
        for k in superseded:
            old = pins[k]
            when, ntools = old.get("pinnedAt", "?"), len(old.get("tools") or {})
            if replace:
                del pins[k]
                ok(f"{n}: superseded prior pin from {when} ({ntools} tool(s))")
            else:
                info(f"{n}: a prior pin from {when} ({ntools} tool(s)) is now "
                     f"superseded. Pass --replace to remove it, or `mcp-pin unpin {n}`")
    save_pins(pins)
    return 1 if fails else 0


def cmd_verify(names):
    pins = load_pins()
    sel = select(names)
    if not sel:
        warn("no matching servers found"); return 0
    head("verifying")
    fails = unpinned = 0
    dirty = False
    for n, s in sel.items():
        if is_legacy_sse(s):
            info(f"{n}: legacy SSE transport. Can't verify (migrate to streamable http)"); continue
        cmd, args = spec_target(s)
        pin = pins.get(identity(n, cmd, args))
        try:
            cur = current_hashes(s)
        except Exception as e:
            bad(f"{n}: cannot verify: {e}"); fails += 1; continue
        if not pin:
            warn(f"{n}: not pinned. Review its tools, then `mcp-pin pin {n}`"); unpinned += 1; continue
        old = pin.get("tools") or {}
        added = sorted(t for t in cur if t not in old)
        removed = sorted(t for t in old if t not in cur)
        changed = sorted(t for t in cur if t in old and cur[t] != old[t])
        if not (added or removed or changed):
            ok(f"{n}: unchanged ({len(cur)} tools)")
            # freshness marker, the nudge warns when this goes stale
            pin["lastVerified"] = time.strftime("%Y-%m-%dT%H:%M:%S")
            dirty = True
        else:
            bad(f"{n}: DRIFT: changed={changed} added={added} removed={removed}")
            bad(f"      a tool changed since you approved it (possible rug-pull). "
                f"Re-vet, then `mcp-pin pin {n}`.")
            fails += 1
    if dirty:
        save_pins(pins)
    head("summary")
    if fails:
        print(f"  {R}{fails} server(s) drifted/failed{X}")
    elif unpinned:
        print(f"  {Y}{unpinned} unpinned server(s). Review and pin{X}")
    else:
        print(f"  {G}all pinned servers unchanged{X}")
    return 1 if fails else 0


def cmd_list(_names):
    pins = load_pins()
    head("pinned servers")
    if not pins:
        info("none yet, run `mcp-pin pin`"); return 0
    for v in sorted(pins.values(), key=lambda x: x.get("name", "")):
        ok(f"{v.get('name')}: {len(v.get('tools') or {})} tool(s)  "
           f"(pinned {v.get('pinnedAt', '?')}, last verified {v.get('lastVerified', 'never')})")
    return 0


def cmd_unpin(names):
    names = [n for n in names if not n.startswith("-")]
    if not names:
        warn("usage: mcp-pin unpin <name> [name…]"); return 2
    pins = load_pins()
    live = set()
    for n, s in discover().items():
        cmd, args = spec_target(s)
        live.add(identity(n, cmd, args))
    head("unpinning")
    removed = matched = 0
    for name in names:
        matches = [k for k in pins if pins[k].get("name") == name]
        matched += len(matches)
        # A name can map to several identities, typically a stale pin left
        # behind after a server's command/args changed (e.g. a migration),
        # plus the fresh re-pin. Deleting the pin for the server AS CONFIGURED
        # HERE because it shares a name with a stale one would silently undo
        # that re-pin, so with multiple matches, keep the live identity.
        # A single match is removed unconditionally: that's the deliberate
        # "unpin this server" case, live or not.
        keep = [k for k in matches if k in live] if len(matches) > 1 else []
        for k in matches:
            if k in keep:
                info(f"{name}: kept the pin for the server as configured here "
                     f"(pinned {pins[k].get('pinnedAt', '?')}). Run "
                     f"`mcp-pin unpin {name}` again to remove it too")
                continue
            ok(f"{name}: pin removed (pinned {pins[k].get('pinnedAt', '?')})")
            del pins[k]; removed += 1
    if not matched:
        warn(f"no pins matched: {', '.join(names)}"); return 0
    if removed:
        save_pins(pins)
    return 0


def cmd_prune(names):
    apply = any(a in ("--yes", "-y") for a in names)
    pins = load_pins()
    live = set()
    for n, s in discover().items():
        cmd, args = spec_target(s)
        live.add(identity(n, cmd, args))
    orphans = {k: v for k, v in pins.items() if k not in live}
    head("prune")
    if not orphans:
        info("no orphaned pins for this context"); return 0
    warn("discovery is relative to the CURRENT dir (./.mcp.json) + ~/.claude.json. "
         "A pin below may belong to ANOTHER repo you're simply not in right now.")
    for v in sorted(orphans.values(), key=lambda x: x.get("name", "")):
        print(f"    {v.get('name')}  (pinned {v.get('pinnedAt', '?')})")
    if not apply:
        info(f"{len(orphans)} orphaned pin(s). Re-run `mcp-pin prune --yes` to remove all, "
             "or `mcp-pin unpin <name>` for specific ones")
        return 0
    for k in orphans:
        del pins[k]
    save_pins(pins)
    ok(f"removed {len(orphans)} orphaned pin(s)")
    return 0


def cmd_tools(argv):
    """Plumbing: print an arbitrary command's tool list as JSON on stdout."""
    if argv and argv[0] == "--":
        argv = argv[1:]
    if not argv:
        warn("usage: mcp-pin tools -- <command> [args…]"); return 2
    try:
        tools = list_tools({"command": argv[0], "args": argv[1:]})
    except Exception as e:
        bad(f"cannot list tools: {e}"); return 1
    print(json.dumps(tools, indent=2, sort_keys=True))
    return 0


def main():
    argv = sys.argv[1:]
    cmd = "verify"
    if argv and argv[0] in ("pin", "verify", "list", "unpin", "prune", "tools"):
        cmd = argv.pop(0)
    return {"pin": cmd_pin, "verify": cmd_verify, "list": cmd_list,
            "unpin": cmd_unpin, "prune": cmd_prune, "tools": cmd_tools}[cmd](argv)


if __name__ == "__main__":
    sys.exit(main())
